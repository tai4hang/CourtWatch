{
  "cli": {
    "version": ">= 3.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      }
    },
    "preview": {
      "distribution": "internal",
      "android": {
        "buildType": "apk"
      },
      "ios": {
        "simulator": true
      }
    },
    "production": {
      "distribution": "store",
      "android": {
        "buildType": "app-bundle"
      },
      "ios": {
        "scheme": "courtwatch"
      }
    }
  },
  "submit": {
    "preview": {
      "ios": {
        "ascAppId": "ADD_YOUR_ASC_APP_ID_HERE"
      }
    },
    "production": {
      "ios": {
        "ascAppId": "ADD_YOUR_ASC_APP_ID_HERE"
      },
      "android": {
        "track": "internal"
      }
    }
  }
}