# Fastlane Appfile for iOS
# https://docs.fastlane.tools/advanced/Appfile/

app_identifier("com.startup.app") # The bundle identifier of your app
apple_id(ENV["APPLE_ID"] || "") # Your Apple ID email

# App Store Connect team
itc_team_id(ENV["APPLE_TEAM_ID"] || "") # App Store Connect Team ID
team_id(ENV["APPLE_TEAM_ID"] || "") # Developer Portal Team ID

# For more information about the Appfile, see:
# https://docs.fastlane.tools/advanced/Appfile/