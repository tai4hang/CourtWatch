# Backend
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000

# Oracle Cloud AI DB
ORACLE_USER=admin
ORACLE_PASSWORD=your_oracle_password
ORACLE_CONNECT_STRING=your_oracle_atp_connection_string
ORACLE_WALLET_LOCATION=./wallet
ORACLE_WALLET_PASSWORD=your_wallet_password

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=your-refresh-token-secret-change-in-production
JWT_REFRESH_EXPIRES_IN=30d

# Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
STRIPE_PRICE_ID_MONTHLY=price_your_monthly_price_id
STRIPE_SUBSCRIPTION_PRODUCT_ID=prod_your_product_id

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:8081

# Firebase Cloud Messaging (for Android push notifications)
FCM_SERVER_KEY=your_fcm_server_key

# Apple Push Notification Service
APNS_TEAM_ID=your_apple_team_id
APNS_KEY_ID=your_apns_key_id
APNS_PRIVATE_KEY_PATH=./certs/apns-auth-key.p8
APNS_BUNDLE_ID=com.yourapp.bundleid

# PostHog Analytics
POSTHOG_API_KEY=your_posthog_api_key
POSTHOG_HOST=https://app.posthog.com

# OAuth Providers
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
FACEBOOK_APP_ID=your_facebook_app_id
FACEBOOK_APP_SECRET=your_facebook_app_secret

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info